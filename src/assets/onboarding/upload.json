
{
  "limits": {
    "maxFileSizeMB": 300,
    "maxFilesPerUpload": 5,
    "acceptedFormats": ["mp3", "mp4", "m4a", "wav", "webm"]
  },
  "processing": {
    "autoTranscribe": true,
    "languageDetection": true,
    "queuePriority": "standard"
  },
  "storage": {
    "provider": "local",
    "uploadPath": "/mnt/data/uploads",
    "retentionPolicyDays": 14
  }
}
